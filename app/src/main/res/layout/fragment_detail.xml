<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tinta_ground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- BOOK -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardBook"
            style="@style/TintaCard"
            android:visibility="gone">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="14dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilEmail"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="Booking email"
                    tools:ignore="HardcodedText">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:inputType="textEmailAddress" android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView style="@style/TintaEyebrow" android:layout_marginTop="10dp" android:text="Duration"
                    tools:ignore="HardcodedText" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/cgDuration"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    app:singleSelection="true" app:selectionRequired="true">
                    <com.google.android.material.chip.Chip android:id="@+id/chip30" style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:checkable="true" android:text="30 min" tools:ignore="HardcodedText" />
                    <com.google.android.material.chip.Chip android:id="@+id/chip60" style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:checkable="true" android:text="60 min" tools:ignore="HardcodedText" />
                    <com.google.android.material.chip.Chip android:id="@+id/chip120" style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:checkable="true" android:text="2 h" tools:ignore="HardcodedText" />
                    <com.google.android.material.chip.Chip android:id="@+id/chipAllDay" style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:checkable="true" android:text="All day" tools:ignore="HardcodedText" />
                </com.google.android.material.chip.ChipGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- MESSAGE input -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardMessage" style="@style/TintaCard" android:visibility="gone">
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilMessage"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:padding="14dp" android:hint="Message shown on the screen"
                app:counterEnabled="true" app:counterMaxLength="232"
                tools:ignore="HardcodedText">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etMessage"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="textMultiLine" android:maxLength="232" android:maxLines="4" />
            </com.google.android.material.textfield.TextInputLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- MESSAGE preview -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardPreview"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#E9EDF1" app:cardCornerRadius="12dp" app:cardElevation="0dp"
            app:strokeColor="@color/tinta_border" app:strokeWidth="1dp"
            android:visibility="gone">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="10dp">
                <TextView style="@style/TintaEyebrow" android:gravity="center"
                    android:text="Your Tinta will show" tools:ignore="HardcodedText" />
                <TextView android:id="@+id/tvPreview"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="8dp" android:background="@drawable/epaper_face_bg"
                    android:minHeight="96dp" android:gravity="center" android:padding="16dp"
                    android:textColor="#111111" android:textSize="20sp" android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- SKETCH -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSketch" style="@style/TintaCard" android:visibility="gone">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:gravity="center_horizontal" android:padding="14dp">
                <TextView style="@style/TintaEyebrow" android:gravity="center"
                    android:text="Draw what your Tinta will show · 62 × 62" tools:ignore="HardcodedText" />
                <com.wakeelectronics.tintatap.DrawingCanvasView
                    android:id="@+id/drawingCanvas"
                    android:layout_width="280dp" android:layout_height="280dp"
                    android:layout_marginTop="10dp" />
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="10dp" android:gravity="center">
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnDrawMode" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="10dp" android:text="Draw" android:textAllCaps="false" tools:ignore="HardcodedText" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnBrushS" style="@style/Widget.Material3.Button.OutlinedButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="4dp" android:text="S" android:textAllCaps="false" tools:ignore="HardcodedText" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnBrushM" style="@style/Widget.Material3.Button.OutlinedButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="4dp" android:text="M" android:textAllCaps="false" tools:ignore="HardcodedText" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnBrushL" style="@style/Widget.Material3.Button.OutlinedButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="L" android:textAllCaps="false" tools:ignore="HardcodedText" />
                </LinearLayout>
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" android:gravity="center">
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnUndo" style="@style/Widget.Material3.Button.TextButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Undo" android:textAllCaps="false" tools:ignore="HardcodedText" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnInvert" style="@style/Widget.Material3.Button.TextButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Invert" android:textAllCaps="false" tools:ignore="HardcodedText" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnClear" style="@style/Widget.Material3.Button.TextButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Clear" android:textAllCaps="false" tools:ignore="HardcodedText" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- INSTANT -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardInstant" style="@style/TintaCard" android:visibility="gone">
            <TextView android:id="@+id/tvInstantDesc"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:padding="16dp" android:gravity="center"
                android:textColor="@color/tinta_muted" android:textSize="14sp" />
        </com.google.android.material.card.MaterialCardView>

        <!-- TAP HERO (shared) -->
        <com.google.android.material.card.MaterialCardView style="@style/TintaCard">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:gravity="center" android:padding="18dp">
                <ImageView android:layout_width="56dp" android:layout_height="56dp"
                    android:src="@drawable/ic_nfc" android:importantForAccessibility="no" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="10dp" android:gravity="center"
                    android:text="Hold your phone to your Tinta"
                    android:textColor="@color/tinta_ink" android:textSize="16sp" android:textStyle="bold"
                    tools:ignore="HardcodedText" />
                <TextView android:id="@+id/tvPending"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="10dp" android:background="@drawable/badge_bg"
                    android:paddingHorizontal="10dp" android:paddingVertical="3dp"
                    android:textColor="@color/tinta_primary" android:textSize="13sp" android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
