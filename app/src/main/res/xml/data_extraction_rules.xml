<?xml version="1.0" encoding="utf-8"?><!--
   Data extraction rules for API 31+ (cloud backup + device transfer).
   The TintaActions prefs hold the user's booking email; exclude it from both.
   https://developer.android.com/about/versions/12/backup-restore#xml-changes
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="TintaActions.xml"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="TintaActions.xml"/>
    </device-transfer>
</data-extraction-rules>
